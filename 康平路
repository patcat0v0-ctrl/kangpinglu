<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<title>康平论坛 Pro</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body {
    font-family: Arial;
    background: #f2f2f2;
    margin: 0;
}

header {
    background: #4a90e2;
    color: white;
    padding: 15px;
    text-align: center;
    font-size: 20px;
}

.container {
    max-width: 800px;
    margin: 20px auto;
    background: white;
    padding: 15px;
    border-radius: 10px;
}

textarea {
    width: 100%;
    height: 80px;
    margin-top: 10px;
}

button {
    margin-top: 10px;
    padding: 10px;
    width: 100%;
    background: #4a90e2;
    color: white;
    border: none;
    border-radius: 5px;
}

.post {
    border-bottom: 1px solid #ddd;
    padding: 10px 0;
}

.floor {
    font-size: 12px;
    color: gray;
}

.owner {
    color: red;
    font-weight: bold;
}
.delete {
    color: red;
    cursor: pointer;
    font-size: 12px;
    float: right;
}
</style>
</head>

<body>

<header>
康平匿名论坛 Pro（升级版）
</header>

<div class="container">

<textarea id="content" placeholder="输入内容..."></textarea>
<button onclick="post()">发布</button>

<div id="posts"></div>

</div>

<script>
// 你可以改成你的名字（楼主标识）
const OWNER = "admin";

let data = JSON.parse(localStorage.getItem("posts") || "[]");

function render(){
    let box = document.getElementById("posts");
    box.innerHTML = "";

    data.forEach((p, i) => {
        box.innerHTML += `
        <div class="post">
            <div class="floor">
                ${i+1}楼
                <span class="delete" onclick="del(${i})">删除</span>
            </div>

            <div>
                ${p.author === OWNER ? '<span class="owner">[楼主]</span>' : ''}
                ${p.text}
            </div>
        </div>`;
    });
}

function post(){
    let text = document.getElementById("content").value;
    if(text.trim() === "") return;

    data.push({
        text: text,
        author: OWNER
    });

    localStorage.setItem("posts", JSON.stringify(data));

    document.getElementById("content").value = "";
    render();
}

function del(i){
    data.splice(i, 1);
    localStorage.setItem("posts", JSON.stringify(data));
    render();
}

render();
</script>

</body>
</html>
